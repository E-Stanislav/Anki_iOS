# Xcode
#
# gitignore source: https://github.com/github/gitignore/blob/main/Swift.gitignore

## Generated .xcodeproj (use xcodegen to regenerate)
# Uncomment below if you prefer to regenerate from project.yml
# *.xcodeproj/

## User settings
xcuserdata/
*.xcuserdatad

## Build generated
build/
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

## CocoaPods
# We recommend against adding the Pods directory to your .gitignore. However
# you should judge for yourself. The optional Cocoapods GitHub template at:
# https://github.com/garriguv/ios-swift-starting-point has a Podfile with
# resources, assets and code, and usually includes a .gitignore that covers
# most of what you need. For bigger projects you can add your own
# .gitignore file or adjust the template below.

# Pods/
# Add this line if you want to avoid checking in source code for CocoaPods projects.
# However this is non-fatal and your .gitignore will still work correctly.
# showPodsInGitignore = true

## Playgrounds
timeline.xctimeline
playground.xcworkspace

# Swift Package Manager
# Add this line if you want to avoid checking in source code for SPM projects.
Packages/
Package.resolved
*.xccheckout

# Xcode - Configured as a Swift Package Manager collection source
.swiftpm/

# Services
#
# .build/

# Mac OS X
#
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleNetworkBackup

# IntelliJ
# https://github.com/joeblau/gitignore.io/wiki/Xcode#intellij-idea
*.iml
.idea/

# VS Code
.vscode/

# AnkiFlow specific
# Temporary files from .apkg import
*.apkg.tmp/
/AnkiFlow.sqlite
/AnkiFlow.sqlite-shm
/AnkiFlow.sqlite-wal

# Temporary
*.tmp
*.temp
*.log
