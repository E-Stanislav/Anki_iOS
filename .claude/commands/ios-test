#!/bin/bash
# iOS Test Skill - Run tests with TDD best practices
# Usage: /ios-test [scheme_name]

set -e

SCHEME="${1:-AnkiFlowTests}"
PROJECT="AnkiFlow.xcodeproj"
CONFIG="Debug"
DESTINATION='id=110BB9C6-3D24-425D-8E2C-1D8066C911A3'

echo "=========================================="
echo "iOS Test - TDD Best Practices"
echo "=========================================="
echo ""

# Check project exists
if [ ! -d "$PROJECT" ]; then
    echo "ERROR: Project $PROJECT not found"
    exit 1
fi

echo "Test scheme: $SCHEME"
echo "Configuration: $CONFIG"
echo ""

# Run tests with coverage
xcodebuild -project "$PROJECT" \
    -scheme "$SCHEME" \
    -configuration "$CONFIG" \
    -destination "$DESTINATION" \
    -parallelizeTargets \
    -jobs $(sysctl -n hw.ncpu) \
    test \
    CODE_SIGN_IDENTITY="" \
    CODE_SIGNING_REQUIRED=NO \
    CODE_SIGNING_ALLOWED=NO \
    -enableCodeCoverage=YES \
    2>&1

TEST_RESULT=$?

echo ""
echo "=========================================="
if [ $TEST_RESULT -eq 0 ]; then
    echo "ALL TESTS PASSED"
else
    echo "TESTS FAILED"
fi
echo "=========================================="

exit $TEST_RESULT