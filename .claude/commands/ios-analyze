#!/bin/bash
# iOS Analyze Skill - Run static analysis with Xcode
# Usage: /ios-analyze [scheme_name]

set -e

SCHEME="${1:-AnkiFlow}"
PROJECT="AnkiFlow.xcodeproj"
CONFIG="Debug"
DESTINATION='id=110BB9C6-3D24-425D-8E2C-1D8066C911A3'

echo "=========================================="
echo "iOS Static Analysis - Best Practices"
echo "=========================================="
echo ""

# Check project exists
if [ ! -d "$PROJECT" ]; then
    echo "ERROR: Project $PROJECT not found"
    exit 1
fi

echo "Analyzing scheme: $SCHEME"
echo "Configuration: $CONFIG"
echo ""

# Run static analysis
xcodebuild -project "$PROJECT" \
    -scheme "$SCHEME" \
    -configuration "$CONFIG" \
    -destination "$DESTINATION" \
    analyze \
    CODE_SIGN_IDENTITY="" \
    CODE_SIGNING_REQUIRED=NO \
    CODE_SIGNING_ALLOWED=NO \
    2>&1

ANALYZE_RESULT=$?

echo ""
echo "=========================================="
if [ $ANALYZE_RESULT -eq 0 ]; then
    echo "ANALYSIS PASSED - No issues found"
else
    echo "ANALYSIS COMPLETED with issues"
fi
echo "=========================================="

exit $ANALYZE_RESULT